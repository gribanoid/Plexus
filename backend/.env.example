# Copy to .env and fill in values

PORT=8080

# PostgreSQL
DATABASE_URL=postgres://plexus:plexus@localhost:5432/plexus?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# JWT (CHANGE IN PRODUCTION)
JWT_SECRET=dev-jwt-secret-change-in-production

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=plexus
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,app://plexus

# Frontend (OIDC callback redirect target)
FRONTEND_URL=http://localhost:3000

# Environment: development | production
ENV=development

# Embed asynq workers in API process (set false when running plexus-worker separately)
RUN_WORKERS=true

# OIDC / SSO (optional — endpoints return 501 when unset)
# For SAML, use an OIDC broker (Keycloak/Authentik); native ACS reserved at /auth/saml/*
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback
